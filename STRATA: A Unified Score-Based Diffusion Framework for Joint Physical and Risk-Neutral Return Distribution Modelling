    out["Heston_calib_rmse"] = float(hp["calib_rmse"])
    out["Heston_feller_slack"] = float(hp["feller_slack"])
    out["martingale_ratio_Heston"] = check_martingale_condition(heston, s0, cfg.data.risk_free, cfg.data.baseline_steps/TRADING_DAYS)["martingale_ratio"]

    rbp = fit_rbergomi_params(train_rets)
    rbp = {"H": float(np.clip(rbp["H"], 0.02, 0.48)), "eta": float(np.clip(rbp["eta"], 1e-4, 5.0)),
           "rho_vol": float(np.clip(rbp["rho_vol"], -0.999, 0.999)), "xi0": float(np.clip(rbp["xi0"], 1e-6, 5.0))}
