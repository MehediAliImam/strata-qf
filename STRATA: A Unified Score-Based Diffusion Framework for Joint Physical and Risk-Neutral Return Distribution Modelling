def download_returns(ticker: str, start_date: str, end_date: str) -> Tuple[np.ndarray, float, pd.DataFrame]:
    LOGGER.info("Downloading %s (%s -> %s)", ticker, start_date, end_date)
    df = yf.download(ticker, start=start_date, end=end_date, auto_adjust=True, progress=False)
    if df is None or len(df) < 400:
        raise RuntimeError(f"Not enough data for {ticker}")
    if isinstance(df.columns, pd.MultiIndex):
        close = df[("Close", ticker)].astype(float)
    else:
        close = df["Close"].astype(float)
    close = close.dropna()
    rets = np.log(close / close.shift(1)).dropna().to_numpy(np.float64)
    s0 = float(close.iloc[-1])
    return rets, s0, pd.DataFrame({"Close": close})


def split_returns(rets: np.ndarray, train_frac: float, val_frac: float) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    n = len(rets)
    n_train = int(n * train_frac)
    n_val = int(n * val_frac)
    return rets[:n_train], rets[n_train:n_train+n_val], rets[n_train+n_val:]


class ReturnWindowDataset(Dataset):
    def __init__(self, rets: np.ndarray, seq_len: int, vol_seq_len: Optional[int] = None):
        self.rets = np.asarray(rets, dtype=np.float32)
        self.seq_len = seq_len
        self.vol_seq_len = vol_seq_len or (2 * seq_len)

    def __len__(self):
        return max(0, len(self.rets) - self.seq_len)

    def __getitem__(self, idx):
        ctx = self.rets[idx:idx+self.seq_len]
        tgt = self.rets[idx+self.seq_len]
        full_end = idx + self.seq_len + 1
        full_start = max(0, full_end - self.vol_seq_len)
        vol_ctx = self.rets[full_start:full_end]
        if len(vol_ctx) < self.vol_seq_len:
            vol_ctx = np.pad(vol_ctx, (self.vol_seq_len - len(vol_ctx), 0))

        def _rv(arr, k):
            w = arr[-k:] if len(arr) >= k else arr
            return float(np.sqrt(np.mean(np.square(w)) + SAFE_EPS))

        rv5 = _rv(vol_ctx[:-1], 5)
        rv10 = _rv(vol_ctx[:-1], 10)
        rv20 = _rv(vol_ctx[:-1], 20)
        prev_rv = _rv(vol_ctx[:-6], 5) if len(vol_ctx) > 6 else rv5
        vov = float(abs(rv5 - prev_rv) / (prev_rv + SAFE_EPS))
        next_abs = float(abs(tgt))
        return {
            "context": torch.tensor(ctx, dtype=TORCH_DTYPE),
            "target": torch.tensor([tgt], dtype=TORCH_DTYPE),
            "vol_context": torch.tensor(vol_ctx[:-1], dtype=TORCH_DTYPE),
            "rv_targets": torch.tensor([rv5, rv10, rv20, vov, next_abs], dtype=TORCH_DTYPE),
        }


