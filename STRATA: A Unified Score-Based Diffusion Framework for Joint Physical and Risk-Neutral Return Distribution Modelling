# Option Surface Construction
# -----------------------------------------------------------------------------
def bs_call_price(s0: float, k: float, tau: float, rate: float, vol: float) -> float:
    if tau <= 0:
        return max(s0 - k, 0.0)
    vol = max(vol, 1e-6)
    d1 = (math.log(s0/k) + (rate + 0.5*vol*vol)*tau) / (vol*math.sqrt(tau))
    d2 = d1 - vol*math.sqrt(tau)
    nd1 = 0.5*(1.0 + math.erf(d1/math.sqrt(2)))
    nd2 = 0.5*(1.0 + math.erf(d2/math.sqrt(2)))
    return s0*nd1 - k*math.exp(-rate*tau)*nd2


def _fetch_real_option_surface(ticker: str, s0: float, cfg: Config) -> Optional[pd.DataFrame]:
    try:
        tk = yf.Ticker(ticker)
        expirations = tk.options
        if not expirations:
            return None
        rows = []
        today = pd.Timestamp.now().normalize()
        for exp_str in expirations[:8]:
            exp_date = pd.Timestamp(exp_str)
            days = max((exp_date - today).days, 1)
            tau = days / TRADING_DAYS
            if tau > 0.50:
                continue
            try:
                chain = tk.option_chain(exp_str)
                calls = chain.calls
            except Exception:
                continue
            k_lo = s0 * cfg.data.option_core_moneyness_lo * 0.95
            k_hi = s0 * cfg.data.option_core_moneyness_hi * 1.05
            calls = calls[(calls["strike"] >= k_lo) & (calls["strike"] <= k_hi)].copy()
            if "bid" in calls.columns and "ask" in calls.columns:
                mid = (calls["bid"] + calls["ask"]) / 2.0
                calls["market_price"] = np.where((calls["bid"]>0) & (calls["ask"]>0), mid, calls["lastPrice"])
            else:
                calls["market_price"] = calls["lastPrice"]
            calls = calls[calls["market_price"] > 0.01]
            for _, row in calls.iterrows():
                rows.append({
                    "tau": tau, "strike": float(row["strike"]), "market_price": float(row["market_price"]),
                    "days": days, "iv": float(row.get("impliedVolatility", np.nan)), "source": "yfinance"
                })
        if len(rows) < 10:
            return None
        return pd.DataFrame(rows)
    except Exception as e:
        LOGGER.warning("Real option fetch failed: %s", e)
        return None


def _build_synthetic_fallback(s0: float, train_rets: np.ndarray, cfg: Config) -> pd.DataFrame:
    vol = float(np.clip(np.std(train_rets)*math.sqrt(TRADING_DAYS), 0.05, 0.80))
    rows = []
    for d in cfg.data.synthetic_option_maturities:
        tau = d / TRADING_DAYS
        for m in cfg.data.synthetic_option_moneyness:
            strike = s0 * m
            price = bs_call_price(s0, strike, tau, cfg.data.risk_free, vol)
            rows.append({"tau": tau, "strike": strike, "market_price": price,
                         "days": d, "iv": vol, "source": "synthetic_bs"})
    return pd.DataFrame(rows)


def build_option_surface(ticker: str, s0: float, train_rets: np.ndarray, cfg: Config) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    opt_df = _fetch_real_option_surface(ticker, s0, cfg)
    if opt_df is None:
        LOGGER.info("Using synthetic BS option surface for %s", ticker)
        opt_df = _build_synthetic_fallback(s0, train_rets, cfg)
    opt_df = opt_df.sort_values(["days", "strike"]).reset_index(drop=True)
    train_df = opt_df.iloc[::2].reset_index(drop=True)
    holdout_df = opt_df.iloc[1::2].reset_index(drop=True)
    core_lo = s0 * cfg.data.option_core_moneyness_lo
    core_hi = s0 * cfg.data.option_core_moneyness_hi
    core_mask = (train_df["strike"] >= core_lo) & (train_df["strike"] <= core_hi) & (train_df["days"] <= cfg.data.option_core_max_days)
    core_df = train_df[core_mask].reset_index(drop=True)
    LOGGER.info("Option surface: train=%d holdout=%d core=%d", len(train_df), len(holdout_df), len(core_df))
    return train_df, holdout_df, core_df


