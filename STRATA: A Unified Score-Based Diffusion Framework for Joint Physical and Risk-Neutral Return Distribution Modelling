# =============================================================================
# ML BASELINE INTERFACE (subprocess + JSON contract)
# =============================================================================
# Design: external ML baselines (TimeGAN, QuantGAN, etc.) live in `baselines/`
# as standalone scripts with their own dependencies. They consume a spec JSON
# and produce a paths .npy file. STRATA evaluates those paths through the SAME
# pipeline used for classical baselines, ensuring metric consistency.
#
# I/O contract:
#   - INPUT: train/val/test raw returns (.npy), option CSVs, spec JSON
#   - OUTPUT: paths .npy of shape (n_paths, horizon_days), per-day raw log-returns
#   - STRATA computes ALL metrics (KS30, RMSE, martingale, MMD)
#
# To add a new ML baseline:
#   1. Create baselines/<name>_runner.py reading --spec and writing paths .npy
#   2. Add the name to cfg.ml_baselines list in main()
# See baselines/README.md for the full contract.
# =============================================================================

import subprocess
from pathlib import Path


def _evaluate_external_paths(sim_rets: np.ndarray, s0: float,
                              test_rets_raw: np.ndarray,
                              option_holdout: pd.DataFrame,
                              cfg: Config) -> Dict[str, float]:
    """Run external-baseline paths through STRATA's evaluation pipeline.

    Same logic as evaluate_p_finance, but takes pre-generated raw returns
    instead of running the diffusion sampler. Ensures metric consistency
    across all baselines (classical + ML).
    """
    sim_rets = np.asarray(sim_rets, dtype=np.float64)
    if sim_rets.ndim != 2:
        raise ValueError(f"expected (n_paths, horizon_days), got shape {sim_rets.shape}")
    sim_prices = safe_returns_to_prices(s0, sim_rets, cfg.data.max_abs_daily_ret, cfg.data.max_price)
    h30 = min(cfg.model.horizon_days, 30)
    real_h30 = make_horizon_returns(test_rets_raw, h30)
    sim_h30 = np.log(np.clip(sim_prices[:, -1], SAFE_NUM_EPS, cfg.data.max_price) / max(s0, SAFE_NUM_EPS))
    ks30 = compute_ks_distance(real_h30, sim_h30)
    ci = bootstrap_ks_ci(sim_h30, real_h30, n_bootstrap=2000, rng_seed=int(cfg.seed))
    holdout_rmse = float("nan")
    if option_holdout is not None and not option_holdout.empty:
        strikes = option_holdout["strike"].to_numpy(float)
        taus = option_holdout["tau"].to_numpy(float)
        market = option_holdout["market_price"].to_numpy(float)
        mc = monte_carlo_call_prices_from_paths(sim_prices, strikes, taus, cfg.data.risk_free)
        holdout_rmse = float(np.sqrt(np.mean((mc - market) ** 2)))
    mart = check_martingale_condition(sim_prices, s0, cfg.data.risk_free, h30 / TRADING_DAYS)
    return {
        "ks30": float(ks30),
        "ks30_ci_hi": float(ci["ci_hi"]),
        "ks30_ci_lo": float(ci["ci_lo"]),
        "holdout_rmse": float(holdout_rmse),
        "martingale_pct": float(mart["martingale_error_pct"]),
        "n_paths": int(sim_rets.shape[0]),
    }


def run_ml_baseline(baseline_name: str, ticker: str, seed: int,
                    train_rets: np.ndarray, val_rets: np.ndarray,
                    test_rets: np.ndarray, option_train_df: pd.DataFrame,
                    option_holdout_df: pd.DataFrame, s0: float,
                    cfg: Config, timeout_sec: int = 7200) -> Dict[str, float]:
    """Spec-out, subprocess-call, paths-in. Then evaluate via STRATA pipeline."""
    io_root = Path(cfg.out_dir) / "baseline_io"
    in_dir = io_root / "inputs"
    out_dir = io_root / "outputs"
    in_dir.mkdir(parents=True, exist_ok=True)
    out_dir.mkdir(parents=True, exist_ok=True)

    tag = f"{ticker}_seed{seed}_{baseline_name.lower()}"
    train_p = in_dir / f"{ticker}_seed{seed}_train.npy"
    val_p   = in_dir / f"{ticker}_seed{seed}_val.npy"
    test_p  = in_dir / f"{ticker}_seed{seed}_test.npy"
    optr_p  = in_dir / f"{ticker}_seed{seed}_option_train.csv"
    opth_p  = in_dir / f"{ticker}_seed{seed}_option_holdout.csv"
    spec_p  = in_dir / f"{tag}_spec.json"
    paths_p = out_dir / f"{tag}_paths.npy"
    res_p   = out_dir / f"{tag}_result.json"

    np.save(train_p, train_rets)
    np.save(val_p, val_rets)
    np.save(test_p, test_rets)
    option_train_df.to_csv(optr_p, index=False)
    option_holdout_df.to_csv(opth_p, index=False)

    spec = {
        "baseline_name": baseline_name,
        "ticker": ticker, "seed": int(seed), "s0": float(s0),
        "risk_free": float(cfg.data.risk_free),
        "horizon_days": int(cfg.model.horizon_days),
        "n_paths_eval": int(cfg.data.n_paths_eval),
        "train_returns_path": str(train_p), "val_returns_path": str(val_p),
        "test_returns_path": str(test_p),
        "option_train_csv": str(optr_p), "option_holdout_csv": str(opth_p),
        "paths_output_path": str(paths_p), "result_json_path": str(res_p),
    }
    with open(spec_p, "w") as f:
        json.dump(spec, f, indent=2)

    runner_script = Path("baselines") / f"{baseline_name.lower()}_runner.py"
    if not runner_script.exists():
        LOGGER.warning("ML baseline %s: runner script %s not found, skipping",
                       baseline_name, runner_script)
        return {}

    try:
        subprocess.run(["python", str(runner_script), "--spec", str(spec_p)],
                       check=True, timeout=timeout_sec)
    except subprocess.TimeoutExpired:
        LOGGER.warning("ML baseline %s timed out after %ds, skipping", baseline_name, timeout_sec)
        return {}
    except subprocess.CalledProcessError as e:
        LOGGER.warning("ML baseline %s subprocess failed (rc=%d), skipping", baseline_name, e.returncode)
        return {}

    if not paths_p.exists():
        LOGGER.warning("ML baseline %s: expected paths file %s not produced, skipping",
                       baseline_name, paths_p)
        return {}

    sim_rets = np.load(paths_p)
    expected_h = int(cfg.model.horizon_days)
    if sim_rets.ndim != 2 or sim_rets.shape[1] != expected_h:
        LOGGER.warning("ML baseline %s: bad shape %s (expected (n_paths,%d)), skipping",
                       baseline_name, sim_rets.shape, expected_h)
        return {}

    metrics = _evaluate_external_paths(sim_rets, s0, test_rets, option_holdout_df, cfg)
    prefix = baseline_name
    return {f"{prefix}_KS30": metrics["ks30"],
            f"{prefix}_KS30_ci_hi": metrics["ks30_ci_hi"],
            f"{prefix}_KS30_ci_lo": metrics["ks30_ci_lo"],
            f"{prefix}_holdout_RMSE": metrics["holdout_rmse"],
            f"{prefix}_martingale_pct": metrics["martingale_pct"],
            f"{prefix}_n_paths": metrics["n_paths"]}


def run_all_ml_baselines(ticker: str, seed: int, train_rets, val_rets, test_rets,
                          option_train_df, option_holdout_df, s0: float,
                          cfg: Config) -> Dict[str, float]:
    names = list(getattr(cfg, "ml_baselines", []) or [])
    if not names:
        return {}
    out = {}
    for name in names:
        LOGGER.info("Running ML baseline: %s on %s seed=%d", name, ticker, seed)
        try:
            m = run_ml_baseline(name, ticker, seed, train_rets, val_rets, test_rets,
                                 option_train_df, option_holdout_df, s0, cfg)
            out.update(m)
            if m:
                LOGGER.info("ML baseline %s | KS30=%.4f RMSE=%.4f mart%%=%.3f",
                             name, m.get(f"{name}_KS30", float("nan")),
                             m.get(f"{name}_holdout_RMSE", float("nan")),
                             m.get(f"{name}_martingale_pct", float("nan")))
        except Exception as e:
            LOGGER.warning("ML baseline %s raised: %s (skipping)", name, e)
    return out


def run_ticker(ticker: str, cfg: Config) -> Dict[str, object]:
    LOGGER.info("Running ticker %s", ticker)
    rets_raw, s0, _ = download_returns(ticker, cfg.data.start_date, cfg.data.end_date)
    train_raw, val_raw, test_raw = split_returns(rets_raw, cfg.data.train_frac, cfg.data.val_frac)
    norm = fit_return_normalizer(train_raw, cfg.data.normaliser_floor)
    train_norm = norm.normalize(train_raw)
    val_norm = norm.normalize(val_raw)

    cfg.current_s0 = s0
    cfg.current_return_std = norm.std
    option_train, option_holdout, option_core = build_option_surface(ticker, s0, train_raw, cfg)
    if not option_core.empty and "iv" in option_core.columns:
        ivs = option_core["iv"].dropna()
        if len(ivs) >= 3:
            cfg.current_target_vol_ann = float(np.clip(ivs.median(), 0.05, 1.5))
    LOGGER.info("Anchor: S0=%.2f ret_std=%.6f target_vol_ann=%.4f", cfg.current_s0, cfg.current_return_std, cfg.current_target_vol_ann)

    # Train P-model
    p_model, sched, p_metrics = fit_p_model(train_norm, val_norm, cfg, cfg.device, s0, test_raw, option_holdout, norm, option_core)
    prices_p, p_eval = evaluate_p_measure(p_model, sched, s0, train_norm, test_raw, option_holdout, cfg, cfg.device, norm)

    # Build path banks for Q
    train_bank_norm = build_path_bank(p_model, sched, train_norm, cfg.data.q_bank_train_anchors, cfg, cfg.device)
    val_seed = val_norm if len(val_norm) > cfg.model.seq_len else train_norm
    val_bank_norm = build_path_bank(p_model, sched, val_seed, cfg.data.q_bank_val_anchors, cfg, cfg.device)
    train_paths = returns_to_prices(s0, norm.denormalize(train_bank_norm), max_price=cfg.data.max_price)
    val_paths = returns_to_prices(s0, norm.denormalize(val_bank_norm), max_price=cfg.data.max_price)

    # Estimate real P-measure drift/vol for Girsanov
    real_mu = float(np.mean(train_raw) * TRADING_DAYS)
    real_sigma = float(np.std(train_raw) * math.sqrt(TRADING_DAYS))

    # Train Q-model
    q_net, q_metrics = train_q_model(train_paths, val_paths, s0, option_train, option_holdout,
                                     val_raw, cfg, cfg.device, real_mu, real_sigma)
    q_eval = evaluate_q_measure(q_net, val_paths, s0, option_holdout, test_raw, cfg, cfg.device)

    # Baselines
    baseline_metrics = evaluate_baselines(s0, train_raw, test_raw, option_holdout, cfg)

    # ML baselines (subprocess interface — see baselines/README.md)
    ml_baseline_metrics = run_all_ml_baselines(
        ticker=ticker, seed=cfg.seed,
        train_rets=train_raw, val_rets=val_raw, test_rets=test_raw,
        option_train_df=option_train, option_holdout_df=option_holdout,
        s0=float(s0), cfg=cfg,
    )
    baseline_metrics.update(ml_baseline_metrics)

    # Collect all metrics
    metrics = {}
    metrics.update(p_metrics)
    metrics.update(p_eval)
    metrics.update(q_metrics)
    metrics.update(q_eval)
    metrics.update(baseline_metrics)
    metrics["risk_free_used"] = float(cfg.data.risk_free)
    metrics["S0"] = float(s0)
    metrics["return_norm_mean"] = float(norm.mean)
    metrics["return_norm_std"] = float(norm.std)

    fin_tree = build_finance_objective_tree(metrics, cfg)

    # Save output
    os.makedirs(cfg.out_dir, exist_ok=True)
    out_path = os.path.join(cfg.out_dir, f"{ticker}_metrics_{cfg.version}.json")
    with open(out_path, "w", encoding="utf-8") as fh:
        json.dump({"ticker": ticker, "config": asdict(cfg), "metrics": metrics, "finance_tree": fin_tree},
                  fh, indent=2, default=str)
    LOGGER.info("Metrics saved -> %s", out_path)

    # Print summary
    LOGGER.info("─" * 70)
    LOGGER.info("  STRATA %s Summary — %s", cfg.version, ticker)
    LOGGER.info("  P KS30 = %.4f (CI hi = %.4f)", metrics.get("P_KS30", float("nan")), metrics.get("P_KS30_ci_hi", float("nan")))
    LOGGER.info("  P holdout RMSE = %.5f", metrics.get("P_holdout_RMSE", float("nan")))
    LOGGER.info("  Q ESS = %.3f, Q KS30 = %.4f", metrics.get("Q_ESS", float("nan")), metrics.get("Q_KS30", float("nan")))
    LOGGER.info("  Q holdout RMSE = %.5f", metrics.get("Q_holdout_RMSE", float("nan")))
    LOGGER.info("  GBM KS30 = %.4f, Heston KS30 = %.4f", metrics.get("GBM_KS30", float("nan")), metrics.get("Heston_KS30", float("nan")))
    LOGGER.info("─" * 70)

    return {"ticker": ticker, "metrics": metrics, "tree": fin_tree}


def _aggregate_runs(out_dir: str, version: str, runs: List[Dict]) -> None:
    """Aggregate per-(ticker,seed) metrics into CSV + LaTeX table.

    Reports mean ± std across seeds for each ticker. Designed to drop
    directly into a QF manuscript's results section.
    """
    if not runs:
        LOGGER.warning("No runs to aggregate")
        return
    rows = []
    for r in runs:
        m = r.get("metrics", {})
        rows.append({
            "ticker": r["ticker"], "seed": r["seed"],
            **{k: v for k, v in m.items() if isinstance(v, (int, float))},
        })
    df = pd.DataFrame(rows)
    csv_path = os.path.join(out_dir, f"runs_per_seed_{version}.csv")
    df.to_csv(csv_path, index=False)
    LOGGER.info("Per-seed CSV -> %s", csv_path)

    headline = ["P_KS30", "P_KS30_ci_hi", "P_holdout_RMSE",
                "Q_KS30", "Q_ESS", "Q_holdout_RMSE",
                "GBM_KS30", "Heston_KS30", "rBergomi_KS30"]
    # Include any ML baseline columns auto-detected
    ml_cols = sorted({c for c in df.columns
                      if c.endswith("_KS30") and c not in headline
                      and not c.startswith(("P_", "Q_", "GBM_", "Heston_", "rBergomi_"))})
    headline = headline + ml_cols

    agg_rows = []
    for tkr, sub in df.groupby("ticker"):
        row = {"ticker": tkr, "n_seeds": len(sub)}
        for c in headline:
            if c in sub.columns:
                vals = sub[c].dropna()
                row[f"{c}_mean"] = float(vals.mean()) if len(vals) else float("nan")
                row[f"{c}_std"]  = float(vals.std(ddof=1)) if len(vals) > 1 else 0.0
        agg_rows.append(row)
    agg_df = pd.DataFrame(agg_rows)
    agg_csv = os.path.join(out_dir, f"results_aggregated_{version}.csv")
    agg_df.to_csv(agg_csv, index=False)
    LOGGER.info("Aggregated CSV -> %s", agg_csv)

    # LaTeX table — paste-ready for QF manuscript
    tex_path = os.path.join(out_dir, f"results_table_{version}.tex")
    with open(tex_path, "w") as fh:
        fh.write("% Auto-generated by STRATA. Mean +/- std across seeds.\n")
        fh.write("\\begin{tabular}{l" + "c" * len(headline) + "}\n\\toprule\n")
        fh.write("Ticker & " + " & ".join(c.replace("_", "\\_") for c in headline) + " \\\\\n\\midrule\n")
        for _, row in agg_df.iterrows():
            cells = [row["ticker"]]
            for c in headline:
                m, s = row.get(f"{c}_mean", float("nan")), row.get(f"{c}_std", float("nan"))
                cells.append(f"{m:.3f} $\\pm$ {s:.3f}" if np.isfinite(m) else "--")
            fh.write(" & ".join(cells) + " \\\\\n")
        fh.write("\\bottomrule\n\\end{tabular}\n")
    LOGGER.info("LaTeX table -> %s", tex_path)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--tickers", nargs="+", default=["SPY", "QQQ", "IWM", "TLT"])
    parser.add_argument("--seeds", type=int, nargs="+", default=[42, 123, 456])
    parser.add_argument("--ml_baselines", nargs="*", default=["TimeGAN"],
                        help="ML baseline names; each needs baselines/<n>_runner.py")
    parser.add_argument("--device", type=str,
                        default="cuda" if torch.cuda.is_available() else "cpu")
    parser.add_argument("--out_dir", type=str, default="strata_outputs")
    parser.add_argument("--no_regime", action="store_true",
                        help="Ablation: disable regime-aware residual (sets regime_residual_scale=0).")
    parser.add_argument("--no_anchor", action="store_true",
                        help="Ablation: disable volatility anchor loss (zeros all anchor weights).")
    parser.add_argument("--no_mmd", action="store_true",
                        help="Ablation: disable MMD supervision (zeros all MMD loss weights).")
    parser.add_argument("--ablation_tag", type=str, default="",
                        help="Extra version suffix for ablation runs.")
    args, _ = parser.parse_known_args()

    LOGGER.info("Multi-run sweep: tickers=%s seeds=%s ml_baselines=%s",
                args.tickers, args.seeds, args.ml_baselines)
    os.makedirs(args.out_dir, exist_ok=True)

    all_runs: List[Dict] = []
    total = len(args.tickers) * len(args.seeds)
    idx = 0
    t_start = time.time()
    for ticker in args.tickers:
        for seed in args.seeds:
            idx += 1
            LOGGER.info("=" * 78)
            LOGGER.info("RUN %d/%d | ticker=%s seed=%d | elapsed=%.1fmin",
                        idx, total, ticker, seed, (time.time() - t_start) / 60.0)
            LOGGER.info("=" * 78)
            cfg = Config()
            cfg.data.tickers = (ticker,)
            cfg.seed = int(seed)
            cfg.device = args.device
            cfg.out_dir = args.out_dir
            cfg.ml_baselines = list(args.ml_baselines)

            # ---- Ablation toggles ----
            ablation_bits = []
            if args.no_regime:
                cfg.model.regime_residual_scale = 0.0
                ablation_bits.append("noregime")
            if args.no_anchor:
                cfg.stage.p_stage1_use_anchor = False
                cfg.stage.p_stage2_anchor_frac = 0.0
                cfg.stage.p_anchor_max_lam = 0.0
                ablation_bits.append("noanchor")
            if args.no_mmd:
                cfg.loss.p_mmd_lam = 0.0
                cfg.loss.p_mmd_stage2_frac = 0.0
                cfg.loss.p_horizon_mmd_lam = 0.0
                ablation_bits.append("nommd")
            if args.ablation_tag:
                ablation_bits.append(args.ablation_tag)
            if ablation_bits:
                cfg.version = cfg.version + "_" + "_".join(ablation_bits)
                LOGGER.info("Ablation active: version=%s", cfg.version)

            set_seed(cfg.seed)
            try:
                res = run_ticker(ticker, cfg)
                res["seed"] = int(seed)
                all_runs.append(res)
                # Per-(ticker,seed) JSON for safe-keeping
                per_path = os.path.join(args.out_dir,
                                        f"{ticker}_seed{seed}_metrics.json")
                with open(per_path, "w") as f:
                    json.dump({"ticker": ticker, "seed": seed,
                               "metrics": res.get("metrics", {})},
                              f, indent=2, default=str)
            except Exception as e:
                LOGGER.exception("Run failed: ticker=%s seed=%d err=%s", ticker, seed, e)

    agg_tag = "strataqf_v16"
    extras = []
    if args.no_regime: extras.append("noregime")
    if args.no_anchor: extras.append("noanchor")
    if args.no_mmd:    extras.append("nommd")
    if args.ablation_tag: extras.append(args.ablation_tag)
    if extras: agg_tag = agg_tag + "_" + "_".join(extras)
    _aggregate_runs(args.out_dir, agg_tag, all_runs)
    LOGGER.info("Sweep complete in %.1fmin. %d/%d runs succeeded.",
                (time.time() - t_start) / 60.0, len(all_runs), total)


if __name__ == "__main__":
    main()
