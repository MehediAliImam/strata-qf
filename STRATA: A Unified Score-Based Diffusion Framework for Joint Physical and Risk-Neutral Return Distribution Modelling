class TimeEmbedding(nn.Module):
    def __init__(self, dim: int):
        super().__init__()
        self.dim = dim
    def forward(self, t: torch.Tensor) -> torch.Tensor:
        half = self.dim // 2
        freqs = torch.exp(-math.log(10000) * torch.arange(0, half, device=t.device) / max(half-1, 1))
        args = t[:, None] * freqs[None, :]
        emb = torch.cat([torch.sin(args), torch.cos(args)], dim=1)
        if emb.shape[1] < self.dim:
            emb = F.pad(emb, (0, self.dim - emb.shape[1]))
        return emb


def compute_context_features_torch(context: torch.Tensor) -> torch.Tensor:
    x = context
    mu = x.mean(dim=1, keepdim=True)
    xc = x - mu
    std = torch.sqrt(torch.mean(xc*xc, dim=1, keepdim=True) + SAFE_EPS)
    abs_mean = x.abs().mean(dim=1, keepdim=True)
    rv = torch.sqrt(torch.mean(x*x, dim=1, keepdim=True) + SAFE_EPS)
    q90 = torch.quantile(x.abs(), 0.90, dim=1, keepdim=True)
    q95 = torch.quantile(x.abs(), 0.95, dim=1, keepdim=True)
    max_abs = x.abs().amax(dim=1, keepdim=True)
    downside = torch.sqrt(torch.mean(torch.clamp(-x, min=0).pow(2), dim=1, keepdim=True) + SAFE_EPS)
    upside = torch.sqrt(torch.mean(torch.clamp(x, min=0).pow(2), dim=1, keepdim=True) + SAFE_EPS)
    if x.shape[1] > 1:
        x0 = x[:, :-1]
        x1 = x[:, 1:]
        acf_abs = (x0.abs() * x1.abs()).mean(dim=1, keepdim=True) / (torch.sqrt((x0.abs()**2).mean(dim=1, keepdim=True)*(x1.abs()**2).mean(dim=1, keepdim=True)) + SAFE_EPS)
        x0c = x0 - x0.mean(dim=1, keepdim=True)
        x1c = x1 - x1.mean(dim=1, keepdim=True)
        ret_acf = (x0c * x1c).mean(dim=1, keepdim=True) / (torch.sqrt((x0c**2).mean(dim=1, keepdim=True)*(x1c**2).mean(dim=1, keepdim=True)) + SAFE_EPS)
    else:
        acf_abs = torch.zeros_like(mu)
        ret_acf = torch.zeros_like(mu)
    return torch.cat([mu, std, abs_mean, rv, acf_abs, ret_acf, q90, q95, max_abs, downside, upside], dim=1)


class VolEncoder(nn.Module):
    def __init__(self, input_len: int, latent_dim: int, hidden_dim: int):
        super().__init__()
        self.gru = nn.GRU(1, hidden_dim, batch_first=True)
        self.feature = nn.Sequential(
            nn.Linear(11, hidden_dim//2), nn.SiLU(),
            nn.Linear(hidden_dim//2, hidden_dim//2), nn.SiLU()
        )
        self.latent = nn.Sequential(
            nn.Linear(hidden_dim + hidden_dim//2, hidden_dim), nn.SiLU(),
            nn.Linear(hidden_dim, latent_dim), nn.Tanh()
        )
        self.proxy_head = nn.Sequential(
            nn.Linear(latent_dim, hidden_dim), nn.SiLU(),
            nn.Linear(hidden_dim, 5)
        )
    def forward(self, vol_context: torch.Tensor):
        _, h = self.gru(vol_context.unsqueeze(-1))
        hlast = h[-1]
        feat = compute_context_features_torch(vol_context)
        femb = self.feature(feat)
        latent = self.latent(torch.cat([hlast, femb], dim=1))
        preds = self.proxy_head(latent)
        return latent, preds


class ScoreNet(nn.Module):
    def __init__(self, cfg: Config):
        super().__init__()
        m = cfg.model
        self.seq_len = m.seq_len
        self.vol_seq_len = m.seq_len * m.vol_encoder_len_mult
        self.num_regimes = m.num_regimes
        self.regime_dim = m.regime_dim
        self.regime_residual_scale = m.regime_residual_scale
        self.regime_gate_temp = m.regime_gate_temp
        self.regime_by_vol_only = m.regime_by_vol_only
        self.freeze_base = False

        self.time_emb = TimeEmbedding(m.time_embed_dim)
        self.ctx = nn.GRU(1, m.p_hidden_dim, num_layers=2, batch_first=True, bidirectional=True, dropout=m.dropout)
        self.ctx_feat = nn.Sequential(
            nn.Linear(11, m.p_hidden_dim//2), nn.SiLU(),
            nn.Linear(m.p_hidden_dim//2, m.p_hidden_dim//2), nn.SiLU()
        )
        self.vol_encoder = VolEncoder(self.vol_seq_len, m.latent_vol_dim, m.vol_hidden_dim)
        regime_in = 2*m.p_hidden_dim + m.p_hidden_dim//2 + m.latent_vol_dim
        self.regime_gate = nn.Sequential(
            nn.Linear(regime_in, m.p_hidden_dim//2), nn.SiLU(),
            nn.Linear(m.p_hidden_dim//2, m.num_regimes)
        )
        self.regime_embed = nn.Parameter(torch.randn(m.num_regimes, m.regime_dim)*0.05)

        in_dim = 2*m.p_hidden_dim + m.p_hidden_dim//2 + m.latent_vol_dim + m.time_embed_dim + 1 + m.regime_dim
        layers = [nn.Linear(in_dim, m.p_hidden_dim), nn.LayerNorm(m.p_hidden_dim), nn.SiLU(), nn.Dropout(m.dropout)]
        for _ in range(m.n_res_blocks):
            layers += [nn.Linear(m.p_hidden_dim, m.p_hidden_dim), nn.LayerNorm(m.p_hidden_dim), nn.SiLU(), nn.Dropout(m.dropout)]
        layers += [nn.Linear(m.p_hidden_dim, 1)]
        self.head = nn.Sequential(*layers)

        self.regime_heads = nn.ModuleList([
            nn.Sequential(nn.Linear(in_dim, m.p_hidden_dim//2), nn.SiLU(), nn.Linear(m.p_hidden_dim//2, 1))
            for _ in range(m.num_regimes)
        ])

    def set_freeze_base(self, freeze: bool):
        self.freeze_base = freeze
        for p in self.head.parameters():
            p.requires_grad = not freeze

    def forward(self, context: torch.Tensor, xt: torch.Tensor, t: torch.Tensor, vol_context: Optional[torch.Tensor] = None):
        _, h = self.ctx(context.unsqueeze(-1))
        hcat = torch.cat([h[-2], h[-1]], dim=1)
        te = self.time_emb(t)
        context_feat = compute_context_features_torch(context)
        cf = self.ctx_feat(context_feat)
        if vol_context is None:
            vol_context = context
        h_next, _ = self.vol_encoder(vol_context)

        regime_state = torch.cat([hcat, cf, h_next], dim=1)
        if self.regime_by_vol_only:
            rv = torch.sqrt(torch.mean(context**2, dim=1) + SAFE_EPS)  # shape (batch,)
            q1 = torch.quantile(rv, 1.0 / self.num_regimes)
            idxs = (rv > q1).long()
            regime_probs = F.one_hot(idxs, self.num_regimes).to(context.dtype)  # (batch, num_regimes)
        else:
            logits = self.regime_gate(regime_state) / max(self.regime_gate_temp, 1e-4)
            idxs = torch.argmax(logits, dim=1)
            regime_probs = F.one_hot(idxs, self.num_regimes).to(context.dtype)
        regime_ctx = regime_probs @ self.regime_embed

        inp = torch.cat([hcat, cf, h_next, xt, te, regime_ctx], dim=1)
        base_score = self.head(inp)
        if self.freeze_base:
            base_score = base_score.detach()
        regime_scores = torch.cat([head(inp) for head in self.regime_heads], dim=1)
        regime_residual = (regime_probs * regime_scores).sum(dim=1, keepdim=True)
        return base_score + self.regime_residual_scale * regime_residual


class GirsanovNet(nn.Module):
    N_FEAT = 6
    def __init__(self, hidden_dim: int = 64):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(self.N_FEAT, hidden_dim), nn.SiLU(),
            nn.Linear(hidden_dim, hidden_dim), nn.SiLU(),
            nn.Linear(hidden_dim, 1)
        )
        with torch.no_grad():
            self.net[-1].weight.mul_(0.01)
            self.net[-1].bias.zero_()
    def forward(self, step_features: torch.Tensor) -> torch.Tensor:
        return self.net(step_features).squeeze(-1)


# -----------------------------------------------------------------------------
# VP-SDE Schedule
# -----------------------------------------------------------------------------
class VPSchedule:
    def __init__(self, beta_min: float, beta_max: float):
        self.beta_min = beta_min
        self.beta_max = beta_max
    def beta(self, t: torch.Tensor) -> torch.Tensor:
        return self.beta_min + t * (self.beta_max - self.beta_min)
    def int_beta(self, t: torch.Tensor) -> torch.Tensor:
        return self.beta_min * t + 0.5 * (self.beta_max - self.beta_min) * t * t
    def alpha_bar(self, t: torch.Tensor) -> torch.Tensor:
        return torch.exp(-self.int_beta(t)).clamp(min=1e-8, max=1.0)
    def marginal_std(self, t: torch.Tensor) -> torch.Tensor:
        return torch.sqrt(1.0 - self.alpha_bar(t) + SAFE_EPS)


# -----------------------------------------------------------------------------
# Loss Functions
# -----------------------------------------------------------------------------
def compute_torch_mmd(x: torch.Tensor, y: torch.Tensor, bandwidth: float = 1.0) -> torch.Tensor:
    x, y = x.reshape(-1, 1), y.reshape(-1, 1)
    bw = max(bandwidth, 1e-6)
    xx = torch.exp(-(x - x.T).pow(2) / (2*bw*bw)).mean()
    yy = torch.exp(-(y - y.T).pow(2) / (2*bw*bw)).mean()
    xy = torch.exp(-(x - y.T).pow(2) / (2*bw*bw)).mean()
    return xx + yy - 2*xy


def tail_preserving_kurt_loss(x: torch.Tensor, target_excess: float = 9.0) -> torch.Tensor:
    x = x.reshape(-1)
    mean = x.mean()
    var = torch.mean((x - mean)**2).clamp_min(SAFE_EPS)
    z = (x - mean) / torch.sqrt(var)
    ex_kurt = torch.mean(z**4) - 3.0
    excess = torch.relu(ex_kurt - target_excess)
    return torch.log1p(excess**2)


def compute_score_fpe_residual(model: ScoreNet, sched: VPSchedule, context: torch.Tensor, cfg: Config, vol_context: Optional[torch.Tensor] = None) -> torch.Tensor:
    if not torch.is_grad_enabled():
        return torch.zeros((), device=context.device, dtype=context.dtype)
    device = context.device
    dtype = context.dtype
    n_colloc = cfg.loss.p_ito_pde_n_colloc
    t_lo, t_hi = cfg.loss.p_ito_pde_t_lo, cfg.loss.p_ito_pde_t_hi
    bsz = context.shape[0]
    idx = torch.randint(0, bsz, (n_colloc,), device=device)
    ctx_c = context[idx]
    vol_c = vol_context[idx] if vol_context is not None else ctx_c
    t_c = torch.rand(n_colloc, device=device, dtype=dtype) * (t_hi - t_lo) + t_lo
    t_c.requires_grad_(True)
    x0_c = ctx_c[:, -1:].detach()
    ab_c = sched.alpha_bar(t_c).unsqueeze(1)
    sig_c = sched.marginal_std(t_c).unsqueeze(1)
    eps_c = torch.randn_like(x0_c)
    x_c = (torch.sqrt(ab_c)*x0_c + sig_c*eps_c).detach()
    x_c.requires_grad_(True)

    eps_pred = model(ctx_c, x_c, t_c, vol_context=vol_c)
    s = -eps_pred / (sig_c + SAFE_EPS)

    ds_dx = torch.autograd.grad(s, x_c, grad_outputs=torch.ones_like(s), create_graph=True, retain_graph=True)[0]
    d2s_dx2 = torch.autograd.grad(ds_dx, x_c, grad_outputs=torch.ones_like(ds_dx), create_graph=True, retain_graph=True)[0]
    ds_dt = torch.autograd.grad(s.sum(dim=1), t_c, grad_outputs=torch.ones_like(s.sum(dim=1)), create_graph=True, retain_graph=True)[0].unsqueeze(1)

    beta = sched.beta(t_c).unsqueeze(1)
    # Corrected residual: no constant term
    residual = ds_dt + 0.5*beta*x_c*ds_dx + 0.5*beta*s - 0.5*beta*d2s_dx2 - beta*s*ds_dx
    return torch.log1p(residual.pow(2).mean())


def dsm_loss_parts(model: ScoreNet, sched: VPSchedule, context: torch.Tensor, target: torch.Tensor,
                   cfg: Config, epoch: int, vol_context: Optional[torch.Tensor] = None):
    bsz = target.shape[0]
    t = torch.rand(bsz, device=target.device, dtype=target.dtype) * 0.999 + 0.0005
    ab = sched.alpha_bar(t).unsqueeze(1)
    sig = sched.marginal_std(t).unsqueeze(1)
    eps = torch.randn_like(target)
    xt = torch.sqrt(ab)*target + sig*eps
    eps_pred = model(context, xt, t, vol_context=vol_context)
    base_loss = F.mse_loss(eps_pred, eps)

    x0_hat = (xt - sig*eps_pred) / torch.sqrt(ab.clamp_min(SAFE_EPS))
    mmd_loss = compute_torch_mmd(x0_hat.squeeze(1), target.squeeze(1), bandwidth=cfg.loss.p_mmd_bandwidth)
    kurt_loss = tail_preserving_kurt_loss(x0_hat.squeeze(1), target_excess=cfg.loss.p_pred_kurt_target)

    ito_pde_loss = torch.zeros((), device=target.device)
    if cfg.loss.p_ito_pde_lam > 0 and epoch >= cfg.current_stage2_start_epoch:
        ito_pde_loss = compute_score_fpe_residual(model, sched, context, cfg, vol_context)

    # In practice, we would add weighted components; here we keep the essential ones.
    total = base_loss
    return total, base_loss, mmd_loss, kurt_loss, ito_pde_loss


def dsm_loss(model: ScoreNet, sched: VPSchedule, context: torch.Tensor, target: torch.Tensor,
             cfg: Config, epoch: int, vol_context: Optional[torch.Tensor] = None) -> torch.Tensor:
    total, *_ = dsm_loss_parts(model, sched, context, target, cfg, epoch, vol_context)
    return total


# -----------------------------------------------------------------------------
# Sampler (Corrected VP-SDE)
# -----------------------------------------------------------------------------
def generate_mrnd_returns(model: ScoreNet, sched: VPSchedule, ctx: torch.Tensor, n_paths: int,
                          cfg: Config, device: str) -> np.ndarray:
    """Correct reverse VP-SDE sampler (drift_scale removed)."""
    was_training = model.training
    model.eval()
    seq = ctx.detach().cpu().numpy().astype(np.float32).copy()
    if seq.ndim == 1:
        seq = np.tile(seq[None, :], (n_paths, 1))
    else:
        seq = np.tile(seq, (n_paths, 1))

    out = []
    steps = max(cfg.sampler.p_sampling_steps, 8)
    dt = -1.0 / steps
    tail_cut = max(int(cfg.sampler.sampler_deterministic_tail_frac * steps), 1)

    with torch.no_grad():
        for _ in range(cfg.model.horizon_days):
            context = torch.tensor(seq[:, -cfg.model.seq_len:], dtype=TORCH_DTYPE, device=device)
            xt = cfg.sampler.sampler_init_noise_scale * torch.randn(n_paths, 1, dtype=TORCH_DTYPE, device=device)
            for i in reversed(range(steps)):
                t_scalar = (i + 1) / steps
                t = torch.full((n_paths,), t_scalar, dtype=TORCH_DTYPE, device=device)
                beta_t = sched.beta(t).unsqueeze(1)
                sig_t = sched.marginal_std(t).unsqueeze(1)
                eps_pred = model(context, xt, t, vol_context=context)
                score = -eps_pred / (sig_t + SAFE_EPS)
                drift = -0.5 * beta_t * xt - beta_t * score   # CORRECTED: no scaling
                if i >= tail_cut:
                    noise = cfg.sampler.sampler_temperature * torch.sqrt(beta_t * (-dt)) * torch.randn_like(xt)
                else:
                    noise = 0.0
                xt = xt + drift * dt + noise
                xt = torch.clamp(xt, -cfg.data.max_abs_norm_ret, cfg.data.max_abs_norm_ret)
            pred = xt.squeeze(1).cpu().numpy().astype(np.float32)
            out.append(pred)
            seq = np.concatenate([seq, pred[:, None]], axis=1)

    rets = np.stack(out, axis=1)
    if was_training:
        model.train()
    return safe_clip_returns(rets, cfg.data.max_abs_norm_ret)


# -----------------------------------------------------------------------------
# Non-overlapping horizon helpers and bootstrap
# -----------------------------------------------------------------------------
def _sim_nonoverlap(sim_rets: np.ndarray, h: int) -> np.ndarray:
    sim_rets = np.asarray(sim_rets, dtype=np.float64)
    if h <= 1:
        return sim_rets.reshape(-1)
    n_paths, n_days = sim_rets.shape
    n_full = (n_days // h) * h
    if n_full == 0:
        return np.array([], dtype=np.float64)
    blocks = sim_rets[:, :n_full].reshape(n_paths, -1, h)
    return blocks.sum(axis=2).reshape(-1)


def _real_nonoverlap(real_rets: np.ndarray, h: int) -> np.ndarray:
    real_rets = np.asarray(real_rets, dtype=np.float64)
    if h <= 1:
        return real_rets.copy()
    n = len(real_rets)
    n_full = (n // h) * h
    if n_full == 0:
        return np.array([], dtype=np.float64)
    return real_rets[:n_full].reshape(-1, h).sum(axis=1)


def bootstrap_ks_ci(sim_rets: np.ndarray, real_rets: np.ndarray,
                    n_bootstrap: int = 2000, alpha: float = 0.05,
                    rng_seed: int = 0) -> Dict[str, float]:
    rng = np.random.default_rng(rng_seed)
    sim_rets = np.asarray(sim_rets, dtype=np.float64)
    real_rets = np.asarray(real_rets, dtype=np.float64)
    n_r, n_s = len(real_rets), len(sim_rets)
    if n_r < 2 or n_s < 2:
        return {"ks": float("nan"), "ci_lo": float("nan"), "ci_hi": float("nan"),
                "n_real": n_r, "n_sim": n_s, "critical_95": float("nan")}
    ks_obs = float(ks_2samp(real_rets, sim_rets).statistic)
    boot_ks = np.empty(n_bootstrap, dtype=np.float64)
    for i in range(n_bootstrap):
        r_b = rng.choice(real_rets, size=n_r, replace=True)
        s_b = rng.choice(sim_rets, size=n_s, replace=True)
        boot_ks[i] = float(ks_2samp(r_b, s_b).statistic)
    ci_lo = float(np.percentile(boot_ks, 100 * alpha / 2))
    ci_hi = float(np.percentile(boot_ks, 100 * (1 - alpha / 2)))
    c_alpha = 1.3581
    critical_95 = c_alpha * math.sqrt((n_r + n_s) / (n_r * n_s))
    return {"ks": ks_obs, "ci_lo": ci_lo, "ci_hi": ci_hi,
            "n_real": n_r, "n_sim": n_s, "critical_95": critical_95,
            "reject_null": ks_obs > critical_95}


def multi_horizon_ks_with_ci(sim_rets: np.ndarray, test_rets_raw: np.ndarray,
                             horizons: Tuple[int, ...] = (1, 5, 30),
                             n_bootstrap: int = 2000, rng_seed: int = 0) -> Dict[str, object]:
    result: Dict[str, object] = {}
    for h in horizons:
        sim_h = _sim_nonoverlap(sim_rets, h)
        real_h = _real_nonoverlap(test_rets_raw, h)
        ci = bootstrap_ks_ci(sim_h, real_h, n_bootstrap=n_bootstrap, rng_seed=rng_seed)
        ci["reject_null"] = bool(ci["ks"] > ci["critical_95"])
        result[h] = ci
    return result


# -----------------------------------------------------------------------------
# Evaluation helpers
# -----------------------------------------------------------------------------
def monte_carlo_call_prices_from_paths(paths: np.ndarray, strikes: np.ndarray, taus: np.ndarray, rate: float) -> np.ndarray:
    prices = []
    horizon = paths.shape[1] - 1
    for k, tau in zip(strikes, taus):
        step = min(horizon, max(1, int(round(TRADING_DAYS * tau))))
        st = paths[:, step]
        payoff = np.maximum(st - float(k), 0.0)
        prices.append(float(np.exp(-rate * tau) * payoff.mean()))
    return np.asarray(prices, dtype=np.float64)


def weighted_martingale_metrics(paths: np.ndarray, weights: np.ndarray,
                                s0: float, rate: float, tau_years: float) -> Dict[str, float]:
    prices = np.clip(paths, SAFE_EPS, 1e9)
    w = _normalise_weights(weights)
    st = prices[:, -1]
    expected_st = float(np.dot(w, st))
    forward = float(s0 * math.exp(rate * tau_years))
    ratio = expected_st / max(forward, SAFE_EPS)
    err_pct = 100.0 * abs(expected_st - forward) / max(forward, SAFE_EPS)
    return {"expected_ST_weighted": expected_st, "forward_price": forward,
            "martingale_ratio": ratio, "martingale_error_pct": err_pct}


def check_martingale_condition(paths: np.ndarray, s0: float, rate: float, tau_years: float) -> Dict[str, float]:
    w = np.full(len(paths), 1.0 / max(len(paths), 1), dtype=np.float64)
    return weighted_martingale_metrics(paths, w, s0, rate, tau_years)


def evaluate_p_finance(model: ScoreNet, sched: VPSchedule, s0: float,
                       ctx_seed_norm: np.ndarray, test_rets_raw: np.ndarray,
                       option_holdout: pd.DataFrame, cfg: Config, device: str,
                       normalizer: ReturnNormalizer, n_paths_override: Optional[int] = None):
    n_paths = n_paths_override or cfg.data.n_paths_eval
    ctx = torch.tensor(ctx_seed_norm[-cfg.model.seq_len:], dtype=TORCH_DTYPE)
    sim_rets_norm = generate_mrnd_returns(model, sched, ctx, n_paths, cfg, device)
    sim_rets = normalizer.denormalize(sim_rets_norm)
    sim_prices = returns_to_prices(s0, sim_rets, max_price=cfg.data.max_price)

    h30 = min(cfg.model.horizon_days, 30)
    sim_h30 = _sim_nonoverlap(sim_rets, h30)
    real_h30 = _real_nonoverlap(test_rets_raw, h30)
    ks30 = compute_ks_distance(real_h30, sim_h30)
    ci = bootstrap_ks_ci(sim_h30, real_h30)

    holdout_rmse = float("nan")
    if not option_holdout.empty:
        strikes = option_holdout["strike"].to_numpy(float)
        taus = option_holdout["tau"].to_numpy(float)
        market = option_holdout["market_price"].to_numpy(float)
        mc = monte_carlo_call_prices_from_paths(sim_prices, strikes, taus, cfg.data.risk_free)
        holdout_rmse = float(np.sqrt(np.mean((mc - market)**2)))

    mart = check_martingale_condition(sim_prices, s0, cfg.data.risk_free, h30 / TRADING_DAYS)
    return {"ks30": ks30, "ks30_ci_hi": ci["ci_hi"], "holdout_rmse": holdout_rmse,
            "martingale_pct": mart["martingale_error_pct"]}


# -----------------------------------------------------------------------------
# P-Model Training (simplified stage gate using CI)
# -----------------------------------------------------------------------------
def fit_p_model(train_rets: np.ndarray, val_rets: np.ndarray, cfg: Config, device: str,
                s0: float, test_rets_raw: np.ndarray, option_holdout: pd.DataFrame,
                normalizer: ReturnNormalizer, option_core: pd.DataFrame):
    sched = VPSchedule(cfg.sampler.beta_min, cfg.sampler.beta_max)
    model = ScoreNet(cfg).to(device)
    train_loader = DataLoader(
        ReturnWindowDataset(train_rets, cfg.model.seq_len),
        batch_size=cfg.training.p_batch_size, shuffle=True, drop_last=True,
        num_workers=cfg.num_workers, pin_memory=cfg.pin_memory
    )
    val_loader = DataLoader(
        ReturnWindowDataset(val_rets, cfg.model.seq_len),
        batch_size=cfg.training.p_batch_size, shuffle=False,
        num_workers=cfg.num_workers, pin_memory=cfg.pin_memory
    )
    opt = torch.optim.AdamW(model.parameters(), lr=cfg.training.p_lr, weight_decay=cfg.training.p_weight_decay)
    scaler = make_grad_scaler(device)

    best_ks30_ci = float("inf")
    best_ckpt_state = None
    gate_consecutive = 0
    stage2_started = False
    audit_snapshots = []

    for epoch in range(1, cfg.training.p_epochs + 1):
        model.train()
        cfg.current_epoch = epoch
        for batch in train_loader:
            batch = to_device(batch, device)
            opt.zero_grad(set_to_none=True)
            with autocast(device_type="cuda", dtype=amp_dtype(device), enabled=amp_enabled(device)):
                loss = dsm_loss(model, sched, batch["context"], batch["target"], cfg, epoch,
                                vol_context=batch.get("vol_context", batch["context"]))
            scaler.scale(loss).backward()
            scaler.unscale_(opt)
            nn.utils.clip_grad_norm_(model.parameters(), cfg.training.grad_clip)
            scaler.step(opt)
            scaler.update()

        # Audit
        if epoch == 1 or epoch % cfg.data.p_finance_audit_every == 0 or epoch == cfg.training.p_epochs:
            fin = evaluate_p_finance(model, sched, s0, train_rets, test_rets_raw, option_holdout,
                                     cfg, device, normalizer, cfg.data.p_finance_audit_n_paths)
            audit_snapshots.append(fin)
            ks30_ci_hi = fin["ks30_ci_hi"]
            LOGGER.info("Audit epoch %d: KS30=%.4f CI_hi=%.4f RMSE=%.4f", epoch, fin["ks30"], ks30_ci_hi, fin["holdout_rmse"])

            # Simplified gate: start stage2 when upper CI of KS30 < threshold for consecutive audits
            if not stage2_started and epoch >= cfg.stage.p_stage2_gate_min_epoch:
                if ks30_ci_hi < cfg.stage.p_stage2_gate_ks30_max:
                    gate_consecutive += 1
                else:
                    gate_consecutive = 0
                if gate_consecutive >= cfg.stage.p_stage2_gate_patience:
                    cfg.current_stage2_start_epoch = epoch + 1
                    stage2_started = True
                    LOGGER.info("Stage 2 gate OPEN at epoch %d", epoch)

            # Save best checkpoint based on KS30 CI upper bound
            if ks30_ci_hi < best_ks30_ci:
                best_ks30_ci = ks30_ci_hi
                best_ckpt_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}
                cfg._best_ckpt_rmse = fin["holdout_rmse"]
                cfg._best_ckpt_mart = fin["martingale_pct"]

    if best_ckpt_state is not None:
        model.load_state_dict(best_ckpt_state)
    model.eval()
    return model, sched, {"P_ks30_ci_hi_best": best_ks30_ci, "P_stage2_start": cfg.current_stage2_start_epoch}


# -----------------------------------------------------------------------------
# Q-Model Training (Girsanov)
# -----------------------------------------------------------------------------
def build_girsanov_step_features(paths: np.ndarray, s0: float) -> np.ndarray:
    n_paths, n_cols = paths.shape
    n_steps = n_cols - 1
    if n_steps < 1:
        return np.zeros((n_paths, 0, 6), dtype=np.float32)
    log_prices = np.log(np.clip(paths, SAFE_EPS, 1e9))
    log_s0 = np.log(max(s0, SAFE_EPS))
    log_rets = np.diff(log_prices, axis=1)
    cum_log_ret = log_prices[:, 1:] - log_s0

    def rolling_std(arr, w):
        out = np.zeros_like(arr)
        for t in range(arr.shape[1]):
            start = max(0, t-w+1)
            out[:, t] = np.std(arr[:, start:t+1], axis=1, ddof=0) + SAFE_EPS
        return out

    vol5 = rolling_std(log_rets, 5)
    vol20 = rolling_std(log_rets, 20)
    time_frac = np.tile(np.linspace(1/n_steps, 1.0, n_steps)[None, :], (n_paths, 1))
    log_money = log_prices[:, 1:] - log_s0
    feats = np.stack([log_rets, cum_log_ret, vol5, vol20, time_frac, log_money], axis=2).astype(np.float32)
    mu = np.nanmean(feats, axis=(0,1), keepdims=True)
    sig = np.nanstd(feats, axis=(0,1), keepdims=True) + 1e-6
    feats = np.clip((feats - mu)/sig, -8.0, 8.0)
    return np.nan_to_num(feats, nan=0.0)


def compute_girsanov_log_weights(lambdas: torch.Tensor, paths: torch.Tensor, s0: float,
                                 mu_ann: float, sigma_ann: float, dt: float = 1/252) -> torch.Tensor:
    log_prices = torch.log(torch.clamp(paths, min=SAFE_EPS))
    log_rets = log_prices[:, 1:] - log_prices[:, :-1]
    drift_per_step = (mu_ann - 0.5*sigma_ann**2) * dt
    sigma_sqrt_dt = sigma_ann * math.sqrt(dt) + SAFE_EPS
    dW = (log_rets - drift_per_step) / sigma_sqrt_dt
    log_rn = -torch.sum(lambdas * dW, dim=1) - 0.5 * dt * torch.sum(lambdas**2, dim=1)
    return torch.clamp(log_rn, -20.0, 20.0)


def compute_arbitrage_penalties(paths: torch.Tensor, weights: torch.Tensor,
                                option_df: pd.DataFrame, s0: float, rate: float) -> Dict[str, torch.Tensor]:
    device = paths.device
    zero = torch.tensor(0.0, device=device, dtype=paths.dtype)
    penalties = {"strike_mono": zero.clone(), "convexity": zero.clone(), "calendar_mono": zero.clone()}
    if option_df.empty or len(option_df) < 3:
        return penalties
    df = option_df.copy().sort_values(["days", "strike"]).reset_index(drop=True)
    n_violations = {"strike_mono": 0, "convexity": 0, "calendar_mono": 0}
    mc_prices = {}
    for _, row in df.iterrows():
        tau = float(row["tau"])
        strike = float(row["strike"])
        key = (tau, strike)
        if key not in mc_prices:
            step = min(paths.shape[1] - 1, max(1, int(round(TRADING_DAYS * tau))))
            st = paths[:, step]
            payoff = torch.clamp(st - strike, min=0.0)
            mc_prices[key] = math.exp(-rate * tau) * torch.sum(weights * payoff)
    for days_val in df["days"].unique():
        slice_df = df[df["days"] == days_val].sort_values("strike")
        strikes = slice_df["strike"].tolist()
        tau = float(slice_df["tau"].iloc[0])
        for i in range(len(strikes) - 1):
            c1 = mc_prices.get((tau, strikes[i]), zero)
            c2 = mc_prices.get((tau, strikes[i+1]), zero)
            violation = torch.clamp(c2 - c1, min=0.0)
            penalties["strike_mono"] = penalties["strike_mono"] + violation**2
            n_violations["strike_mono"] += 1
        for i in range(1, len(strikes) - 1):
            c_lo = mc_prices.get((tau, strikes[i-1]), zero)
            c_mid = mc_prices.get((tau, strikes[i]), zero)
            c_hi = mc_prices.get((tau, strikes[i+1]), zero)
            butterfly = c_lo - 2.0 * c_mid + c_hi
            violation = torch.clamp(-butterfly, min=0.0)
            penalties["convexity"] = penalties["convexity"] + violation**2
            n_violations["convexity"] += 1
    for strike_val in df["strike"].unique():
        slice_df = df[df["strike"] == strike_val].sort_values("days")
        if len(slice_df) < 2:
            continue
        taus_list = slice_df["tau"].tolist()
        for i in range(len(taus_list) - 1):
            c_short = mc_prices.get((taus_list[i], strike_val), zero)
            c_long = mc_prices.get((taus_list[i+1], strike_val), zero)
            violation = torch.clamp(c_short - c_long, min=0.0)
            penalties["calendar_mono"] = penalties["calendar_mono"] + violation**2
            n_violations["calendar_mono"] += 1
    for k in penalties:
        if n_violations[k] > 0:
            penalties[k] = penalties[k] / n_violations[k]
    return penalties


def train_q_model(train_paths: np.ndarray, val_paths: np.ndarray, s0: float,
                  option_train: pd.DataFrame, option_holdout: pd.DataFrame,
                  val_rets: np.ndarray, cfg: Config, device: str,
                  real_mu_ann: float, real_sigma_ann: float):
    g_net = GirsanovNet(hidden_dim=cfg.model.q_hidden_dim).to(device)
    opt = torch.optim.AdamW(g_net.parameters(), lr=cfg.training.q_lr, weight_decay=cfg.training.q_weight_decay)
    scaler = make_grad_scaler(device)

    train_feats = torch.tensor(build_girsanov_step_features(train_paths, s0), dtype=TORCH_DTYPE, device=device)
    val_feats = torch.tensor(build_girsanov_step_features(val_paths, s0), dtype=TORCH_DTYPE, device=device)
    train_prices_t = torch.tensor(train_paths, dtype=TORCH_DTYPE, device=device)
    val_prices_t = torch.tensor(val_paths, dtype=TORCH_DTYPE, device=device)

    best_val_score = float("inf")
    best_state = None
    dt = 1.0 / TRADING_DAYS

    for epoch in range(cfg.training.q_epochs):
        g_net.train()
        opt.zero_grad(set_to_none=True)
        with autocast(device_type="cuda", dtype=amp_dtype(device), enabled=amp_enabled(device)):
            lambdas = g_net(train_feats)
            log_w = compute_girsanov_log_weights(lambdas, train_prices_t, s0, real_mu_ann, real_sigma_ann, dt)
            w_soft = F.softmax(log_w, dim=0)

            # Option pricing loss
            opt_loss = torch.tensor(0.0, device=device)
            if not option_train.empty:
                for _, row in option_train.iterrows():
                    tau = row["tau"]
                    strike = row["strike"]
                    mkt = row["market_price"]
                    step = min(train_paths.shape[1]-1, max(1, int(round(TRADING_DAYS * tau))))
                    st = train_prices_t[:, step]
                    payoff = torch.clamp(st - strike, min=0.0)
                    cq = math.exp(-cfg.data.risk_free * tau) * torch.sum(w_soft * payoff)
                    opt_loss = opt_loss + ((cq - mkt) / max(mkt, 1e-4))**2
                opt_loss = opt_loss / len(option_train)

            # Martingale constraint
            expected_st = torch.sum(w_soft * train_prices_t[:, -1])
            forward = s0 * math.exp(cfg.data.risk_free * (train_paths.shape[1]-1) / TRADING_DAYS)
            mart_gap = torch.abs(expected_st - forward) / max(forward, 1e-8)

            # Entropy regularisation
            kl = 0.5 * dt * torch.mean(torch.sum(lambdas**2, dim=1))
            lam = cfg.loss.q_opt_lam_start + (epoch / max(cfg.training.q_epochs-1, 1)) * (cfg.loss.q_opt_lam_end - cfg.loss.q_opt_lam_start)

            # Arbitrage penalties
            arb_pen = compute_arbitrage_penalties(train_prices_t, w_soft, option_train, s0, cfg.data.risk_free)
            arb_loss = (cfg.loss.q_arb_mono_lam * arb_pen["strike_mono"] +
                        cfg.loss.q_arb_convex_lam * arb_pen["convexity"] +
                        cfg.loss.q_arb_calendar_lam * arb_pen["calendar_mono"])

            loss = opt_loss + lam * kl + cfg.loss.q_martingale_lam * mart_gap + arb_loss

        scaler.scale(loss).backward()
        scaler.unscale_(opt)
        nn.utils.clip_grad_norm_(g_net.parameters(), cfg.training.grad_clip)
        scaler.step(opt)
        scaler.update()

        # Validation
        g_net.eval()
        with torch.no_grad():
            val_lambdas = g_net(val_feats)
            val_log_w = compute_girsanov_log_weights(val_lambdas, val_prices_t, s0, real_mu_ann, real_sigma_ann, dt)
        val_w = girsanov_weights_from_log(val_log_w.cpu().numpy())
        val_ess = compute_ess(val_w)
        real_h30 = _real_nonoverlap(val_rets, min(cfg.model.horizon_days, 30))
        val_terminal = np.log(np.clip(val_paths[:, -1], SAFE_EPS, 1e9)) - np.log(s0)
        rng = np.random.default_rng(cfg.seed + epoch)
        draw = rng.choice(val_terminal, size=min(2000, len(val_terminal)), replace=True, p=_normalise_weights(val_w))
        val_ks30 = compute_ks_distance(draw, real_h30)
        mart = weighted_martingale_metrics(val_paths, val_w, s0, cfg.data.risk_free, (val_paths.shape[1]-1)/TRADING_DAYS)
        val_score = 2.5*val_ks30 + 0.5*(mart["martingale_error_pct"]/100.0)

        if val_score < best_val_score:
            best_val_score = val_score
            best_state = {k: v.detach().clone() for k, v in g_net.state_dict().items()}

    g_net.load_state_dict(best_state)
    g_net._mu_ann = real_mu_ann
    g_net._sigma_ann = real_sigma_ann
    return g_net, {"Q_best_score": best_val_score}


