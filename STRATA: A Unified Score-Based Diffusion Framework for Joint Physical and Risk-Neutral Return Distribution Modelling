def set_seed(seed: int) -> None:
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)


def to_device(batch: Dict[str, torch.Tensor], device: str) -> Dict[str, torch.Tensor]:
    return {k: v.to(device) for k, v in batch.items()}


def safe_clip_returns(rets: np.ndarray, max_abs_ret: float) -> np.ndarray:
    rets = np.asarray(rets, dtype=np.float64)
    rets = np.nan_to_num(rets, nan=0.0, posinf=max_abs_ret, neginf=-max_abs_ret)
    return np.clip(rets, -max_abs_ret, max_abs_ret)


def returns_to_prices(s0: float, rets: np.ndarray, max_price: float = 1e9) -> np.ndarray:
    rets = np.asarray(rets, dtype=np.float64)
    log_paths = np.cumsum(rets, axis=1)
    prices = s0 * np.exp(np.clip(log_paths, -50.0, 50.0))
    prices = np.concatenate([np.full((len(prices), 1), s0), prices], axis=1)
    return np.clip(prices, SAFE_EPS, max_price)


def make_horizon_returns(rets: np.ndarray, horizon: int) -> np.ndarray:
    if len(rets) < horizon or horizon <= 0:
        return np.array([], dtype=np.float64)
    return np.convolve(rets, np.ones(horizon, dtype=np.float64), mode="valid")


def compute_ks_distance(a: np.ndarray, b: np.ndarray) -> float:
    if len(a) == 0 or len(b) == 0:
        return float("nan")
    return float(ks_2samp(a, b).statistic)


def compute_mmd(a: np.ndarray, b: np.ndarray, gamma: Optional[float] = None) -> float:
    a = np.asarray(a, dtype=np.float64).reshape(-1, 1)
    b = np.asarray(b, dtype=np.float64).reshape(-1, 1)
    if len(a) == 0 or len(b) == 0:
        return float("nan")
    rng = np.random.default_rng(123)
    if len(a) > 1500:
        a = a[rng.choice(len(a), 1500, replace=False)]
    if len(b) > 1500:
        b = b[rng.choice(len(b), 1500, replace=False)]
    z = np.vstack([a, b]).ravel()
    if gamma is None:
        med = np.median(np.abs(z[:, None] - z[None, :]))
        gamma = 1.0 / (2.0 * max(med, 1e-3) ** 2)
    def k(x, y):
        d2 = (x - y.T) ** 2
        return np.exp(-gamma * d2)
    kaa = k(a, a)
    kbb = k(b, b)
    kab = k(a, b)
    return float(kaa.mean() + kbb.mean() - 2.0 * kab.mean())


def _normalise_weights(weights: np.ndarray) -> np.ndarray:
    w = np.asarray(weights, dtype=np.float64)
    w = np.clip(w, 0, None)
    s = w.sum()
    if s <= 0:
        return np.ones_like(w) / len(w)
    return w / s


def compute_ess(weights: np.ndarray) -> float:
    w = _normalise_weights(weights)
    return 1.0 / (len(w) * (w**2).sum() + SAFE_EPS)


def girsanov_weights_from_log(log_w: np.ndarray) -> np.ndarray:
    log_w = np.asarray(log_w, dtype=np.float64)
    log_w = np.nan_to_num(log_w, nan=-20.0, posinf=20.0, neginf=-20.0)
    log_w = log_w - np.max(log_w)
    return _normalise_weights(np.exp(log_w))


