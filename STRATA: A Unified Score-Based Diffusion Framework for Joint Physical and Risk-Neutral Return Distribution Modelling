def fit_gbm_params(train_rets: np.ndarray) -> Tuple[float, float]:
    mu = float(np.mean(train_rets))
    sigma = float(np.std(train_rets, ddof=0))
    return mu, max(sigma, 1e-6)


def simulate_gbm_paths(s0: float, mu: float, sigma: float, n_steps: int, n_paths: int, cfg: Config) -> np.ndarray:
    dt = 1.0 / TRADING_DAYS
    z = np.random.randn(n_paths, n_steps)
    rets = (mu - 0.5 * sigma**2) * dt + sigma * math.sqrt(dt) * z
    rets = safe_clip_returns(rets, cfg.data.max_abs_daily_ret)
    return returns_to_prices(s0, rets, max_price=cfg.data.max_price)


def _heston_cf(u: np.ndarray, s0: float, rate: float, tau: float,
               v0: float, kappa: float, theta: float, xi: float, rho: float) -> np.ndarray:
    u = np.asarray(u, dtype=np.complex128)
    iu = 1j * u
    d = np.sqrt((rho * xi * iu - kappa)**2 + xi**2 * (iu + u**2))
    g = (kappa - rho * xi * iu - d) / (kappa - rho * xi * iu + d + 1e-30)
    exp_d = np.exp(np.clip(-d * tau, -500, 500))
    C = (kappa * theta / (xi**2 + 1e-30)) * (
        (kappa - rho * xi * iu - d) * tau
        - 2.0 * np.log(np.where(np.abs(1.0 - g * exp_d) < 1e-30,
                                1e-30, (1.0 - g * exp_d) / (1.0 - g + 1e-30)))
    )
    D = ((kappa - rho * xi * iu - d) / (xi**2 + 1e-30)) * ((1.0 - exp_d) / (1.0 - g * exp_d + 1e-30))
    log_s0 = np.log(max(float(s0), 1e-8))
    result = np.exp(np.clip(C + D * v0 + iu * (log_s0 + rate * tau), -500, 500))
    result = np.where(np.isfinite(result), result, 0.0 + 0.0j)
    return result


def _carr_madan_call(s0: float, rate: float, tau: float, strikes: np.ndarray,
                     v0: float, kappa: float, theta: float, xi: float, rho: float,
                     N: int = 4096, alpha: float = 1.5, eta: float = 0.25) -> np.ndarray:
    lam = 2.0 * math.pi / (N * eta)
    b = N * lam / 2.0
    u_j = np.arange(N) * eta
    k_grid = -b + np.arange(N) * lam
    cf_vals = _heston_cf(u_j - (alpha + 1.0) * 1j, s0, rate, tau, v0, kappa, theta, xi, rho)
    denom = (alpha**2 + alpha - u_j**2) + 1j * (2.0 * alpha + 1.0) * u_j
    denom = np.where(np.abs(denom) < 1e-30, 1e-30, denom)
    psi = np.exp(-rate * tau) * cf_vals / denom
    simpson = 3.0 + (-1.0) ** (np.arange(N) + 1)
    simpson[0] = 1.0
    simpson = simpson / 3.0
    fft_input = np.exp(1j * b * u_j) * psi * eta * simpson
    fft_output = np.fft.fft(fft_input)
    call_grid = (np.exp(-alpha * k_grid) / math.pi) * fft_output.real
    log_strikes = np.log(np.clip(strikes, 1e-8, None))
    prices = np.interp(log_strikes, k_grid, call_grid)
    intrinsic = np.maximum(float(s0) * np.exp(rate * tau) - strikes, 0.0) * np.exp(-rate * tau)
    return np.maximum(prices, intrinsic)


def fit_heston_params(train_rets: np.ndarray, option_surface: Optional[pd.DataFrame] = None,
                      s0: Optional[float] = None, rate: float = 0.0) -> Dict[str, float]:
    rets = np.asarray(train_rets, dtype=np.float64)
    n = len(rets)
    var_daily = float(np.var(rets))
    var_ann = var_daily * TRADING_DAYS
    v0_mm = max(var_ann, 0.01)
    theta_mm = max(var_ann, 0.01)
    sq = rets**2
    if n > 2:
        sq_mu = sq.mean()
        sq_c = sq - sq_mu
        acf_num = float(np.dot(sq_c[:-1], sq_c[1:]) / max(n-1, 1))
        acf_den = float(np.dot(sq_c, sq_c) / max(n, 1))
        rho_sq = acf_num / max(acf_den, 1e-12)
        rho_sq = float(np.clip(rho_sq, 1e-6, 1.0-1e-6))
        kappa_mm = float(-np.log(rho_sq) * TRADING_DAYS)
    else:
        kappa_mm = 2.0
    kappa_mm = float(np.clip(kappa_mm, 0.1, 20.0))
    window = 20
    if n >= 2 * window:
        n_full = (n // window) * window
        rv_blocks = rets[:n_full].reshape(-1, window)
        rv_windows = np.var(rv_blocks, axis=1) * TRADING_DAYS
        rv_mean = float(np.mean(rv_windows))
        rv_std = float(np.std(rv_windows, ddof=1)) if len(rv_windows) > 1 else 0.0
        xi_mm = rv_std / max(rv_mean, 1e-8) * math.sqrt(TRADING_DAYS / window)
    else:
        xi_mm = 0.5
    xi_mm = float(np.clip(xi_mm, 0.05, 5.0))
    if n >= 3:
        r_mid = rets[1:-1]
        abs_diff = np.abs(rets[2:]) - np.abs(rets[:-2])
        r_c = r_mid - r_mid.mean()
        d_c = abs_diff - abs_diff.mean()
        num = float(np.dot(r_c, d_c))
        den = float(np.sqrt(np.dot(r_c, r_c) * np.dot(d_c, d_c) + 1e-12))
        rho_mm = float(np.clip(num / den, -0.999, 0.999))
    else:
        rho_mm = -0.6

    if option_surface is None or option_surface.empty or s0 is None:
        feller = 2.0 * kappa_mm * theta_mm - xi_mm**2
        return {"v0": v0_mm, "kappa": kappa_mm, "theta": theta_mm, "xi": xi_mm, "rho": rho_mm,
                "calib_rmse": 0.0, "feller_slack": feller, "calib_method": "moment_matching"}

    strikes = option_surface["strike"].to_numpy(float)
    taus = option_surface["tau"].to_numpy(float)
    market = option_surface["market_price"].to_numpy(float)
    s0_f = float(s0)

    def _objective(params):
        v0_c, kappa_c, theta_c, xi_c, rho_c = params
        feller = 2.0 * kappa_c * theta_c - xi_c**2
        penalty = 50.0 * max(-feller, 0.0)**2
        rel_sq_parts = []
        for tau_val in np.unique(taus):
            mask = np.abs(taus - tau_val) < 1e-8
            k_slice = strikes[mask]
            m_slice = market[mask]
            try:
                model_prices = _carr_madan_call(s0_f, rate, tau_val, k_slice, v0_c, kappa_c, theta_c, xi_c, rho_c)
                rel_errs = (model_prices - m_slice) / np.maximum(m_slice, 0.01)
                rel_sq_parts.append(float(np.mean(rel_errs**2)))
            except Exception:
                rel_sq_parts.append(1e6)
        return float(np.mean(rel_sq_parts)) + penalty

    bounds = [(0.005, 3.0), (0.1, 25.0), (0.005, 3.0), (0.05, 6.0), (-0.99, 0.50)]
    x0_seed = [float(np.clip(v0_mm, bounds[0][0], bounds[0][1])),
               float(np.clip(kappa_mm, bounds[1][0], bounds[1][1])),
               float(np.clip(theta_mm, bounds[2][0], bounds[2][1])),
               float(np.clip(xi_mm, bounds[3][0], bounds[3][1])),
               float(np.clip(rho_mm, bounds[4][0], bounds[4][1]))]
    alternative_seeds = [x0_seed,
                         [max(var_ann*0.5, 0.01), 3.0, max(var_ann, 0.01), 0.8, -0.75],
                         [max(var_ann*1.5, 0.01), 8.0, max(var_ann*0.8, 0.01), 1.5, -0.50]]
    best_result = None
    best_obj = float("inf")
    for i_start, seed_point in enumerate(alternative_seeds):
        clamped = [float(np.clip(seed_point[j], bounds[j][0], bounds[j][1])) for j in range(5)]
        try:
            res = differential_evolution(_objective, bounds, seed=42+i_start, maxiter=300, tol=1e-6,
                                         init="sobol", x0=clamped, polish=True)
            if res.fun < best_obj:
                best_obj = res.fun
                best_result = res
        except Exception:
            continue
    if best_result is not None:
        v0_c, kappa_c, theta_c, xi_c, rho_c = best_result.x
        calib_rmse = float(np.sqrt(max(best_result.fun, 0.0)))
        LOGGER.info("Heston FFT calib | v0=%.4f kappa=%.3f theta=%.4f xi=%.3f rho=%.3f | relRMSE=%.6f",
                    v0_c, kappa_c, theta_c, xi_c, rho_c, calib_rmse)
        calib_method = "carr_madan_fft"
    else:
        v0_c, kappa_c, theta_c, xi_c, rho_c = v0_mm, kappa_mm, theta_mm, xi_mm, rho_mm
        calib_rmse = 0.0
        calib_method = "moment_matching_fallback"
        LOGGER.warning("Heston FFT calibration failed, using moment-matching fallback")

    feller = 2.0 * kappa_c * theta_c - xi_c**2
    return {"v0": float(v0_c), "kappa": float(kappa_c), "theta": float(theta_c),
            "xi": float(xi_c), "rho": float(rho_c), "calib_rmse": calib_rmse,
            "feller_slack": feller, "calib_method": calib_method}


def simulate_heston_paths(s0: float, rate: float, v0: float, kappa: float, theta: float,
                          xi: float, rho: float, n_steps: int, n_paths: int, cfg: Config) -> np.ndarray:
    dt = 1.0 / TRADING_DAYS
    prices = np.full((n_paths, n_steps+1), float(s0), dtype=np.float64)
    v = np.full(n_paths, float(max(v0, 1e-6)), dtype=np.float64)
    for t in range(1, n_steps+1):
        z1 = np.random.randn(n_paths)
        z2 = np.random.randn(n_paths)
        w1 = z1
        w2 = rho * z1 + math.sqrt(max(1.0 - rho**2, 1e-6)) * z2
        v = np.clip(v + kappa * (theta - v) * dt + xi * np.sqrt(np.clip(v, 1e-8, None)) * math.sqrt(dt) * w2, 1e-8, 4.0)
        lr = (rate - 0.5 * v) * dt + np.sqrt(v * dt) * w1
        lr = np.clip(lr, -cfg.data.max_abs_daily_ret, cfg.data.max_abs_daily_ret)
        prices[:, t] = np.clip(prices[:, t-1] * np.exp(lr), SAFE_EPS, cfg.data.max_price)
    return prices


def fit_rbergomi_params(train_rets: np.ndarray) -> Dict[str, float]:
    rets = np.asarray(train_rets, dtype=np.float64)
    n = len(rets)
    vol = float(np.std(rets) * math.sqrt(TRADING_DAYS))
    xi0 = max(vol**2, 0.02)
    abs_rets = np.abs(rets)
    max_lag = min(40, n // 4)
    if max_lag >= 3:
        lags = np.arange(1, max_lag+1)
        variogram = np.array([np.mean((abs_rets[lag:] - abs_rets[:-lag])**2) for lag in lags])
        valid = variogram > 0
        if valid.sum() >= 3:
            log_lags = np.log(lags[valid].astype(float))
            log_var = np.log(variogram[valid])
            slope, _ = np.polyfit(log_lags, log_var, 1)
            H = float(np.clip(slope/2.0, 0.02, 0.48))
        else:
            H = 0.10
    else:
        H = 0.10
    window = 20
    if n >= 2 * window:
        n_full = (n // window) * window
        rv_blocks = rets[:n_full].reshape(-1, window)
        rv_windows = np.var(rv_blocks, axis=1) * TRADING_DAYS
        rv_mean = float(np.mean(rv_windows))
        rv_std = float(np.std(rv_windows, ddof=1)) if len(rv_windows) > 1 else 0.0
        eta = rv_std / max(rv_mean, 1e-8) * math.sqrt(TRADING_DAYS / window)
        eta = float(np.clip(eta, 0.3, 4.0))
    else:
        eta = 1.2
    if n >= 3:
        r_mid = rets[1:-1]
        abs_diff = np.abs(rets[2:]) - np.abs(rets[:-2])
        r_c = r_mid - r_mid.mean()
        d_c = abs_diff - abs_diff.mean()
        num = float(np.dot(r_c, d_c))
        den = float(np.sqrt(np.dot(r_c, r_c) * np.dot(d_c, d_c) + 1e-12))
        rho_vol = float(np.clip(num / den, -0.99, 0.99))
    else:
        rho_vol = -0.7
    LOGGER.info("rBergomi params | H=%.3f eta=%.3f rho=%.3f xi0=%.4f", H, eta, rho_vol, xi0)
    return {"H": H, "eta": eta, "rho_vol": rho_vol, "xi0": xi0}


def simulate_rbergomi_paths(s0: float, rate: float, H: float, eta: float, rho_vol: float,
                            xi0: float, n_steps: int, n_paths: int, cfg: Config) -> np.ndarray:
    if n_steps > 504:
        raise ValueError("rBergomi steps > 504 not supported. Reduce horizon or baseline_steps.")
    dt = 1.0 / TRADING_DAYS
    H = np.clip(H, 0.02, 0.48)
    idx = np.arange(n_steps)
    diff = idx[:, None] - idx[None, :]
    twoH = 2.0 * H
    C = 0.5 * (np.abs(diff+1)**twoH + np.abs(diff-1)**twoH - 2*np.abs(diff)**twoH) * (dt**twoH)
    C += np.eye(n_steps) * 1e-10
    L = np.linalg.cholesky(C)
    Z_vol = np.random.randn(n_steps, n_paths)
    dW_H = L @ Z_vol
    W_H = np.cumsum(dW_H, axis=0)
    Z_perp = np.random.randn(n_steps, n_paths)
    prices = np.full((n_paths, n_steps+1), s0)
    sqrt_1mrho2 = math.sqrt(max(1 - rho_vol**2, 1e-6))
    for t in range(1, n_steps+1):
        ti = t - 1
        log_vol = np.log(xi0) + eta * W_H[ti] - 0.5 * eta**2 * (t*dt)**(2*H)
        vol = np.clip(np.exp(np.clip(log_vol, -10, np.log(5))), 1e-6, 5)
        dW_S = rho_vol * dW_H[ti] + sqrt_1mrho2 * math.sqrt(dt) * Z_perp[ti]
        lr = (rate - 0.5*vol)*dt + np.sqrt(vol)*dW_S
        lr = np.clip(lr, -cfg.data.max_abs_daily_ret, cfg.data.max_abs_daily_ret)
        prices[:, t] = np.clip(prices[:, t-1] * np.exp(lr), SAFE_EPS, cfg.data.max_price)
    return prices


def evaluate_baselines(s0: float, train_rets: np.ndarray, test_rets: np.ndarray,
                       option_holdout: pd.DataFrame, cfg: Config) -> Dict[str, float]:
    out: Dict[str, float] = {}
    real_h30 = make_horizon_returns(test_rets, min(cfg.model.horizon_days, 30))
    real_h5 = make_horizon_returns(test_rets, 5)
    real_h1 = make_horizon_returns(test_rets, 1)

    mu, sigma = fit_gbm_params(train_rets)
    gbm = simulate_gbm_paths(s0, mu, sigma, cfg.data.baseline_steps, cfg.data.gbm_paths, cfg)
    gbm_rets = np.diff(np.log(np.clip(gbm, SAFE_EPS, 1e9)), axis=1).reshape(-1)
    for h, real in [(1, real_h1), (5, real_h5), (min(cfg.model.horizon_days, 30), real_h30)]:
        sim_h = make_horizon_returns(gbm_rets, h)
        out[f"GBM_KS{h}"] = compute_ks_distance(sim_h, real)
        out[f"GBM_MMD{h}"] = compute_mmd(sim_h, real)
