def evaluate_p_measure(model: ScoreNet, sched: VPSchedule, s0: float, ctx_seed_norm: np.ndarray,
                       test_rets_raw: np.ndarray, option_holdout: pd.DataFrame,
                       cfg: Config, device: str, normalizer: ReturnNormalizer) -> Tuple[np.ndarray, Dict[str, float]]:
    ctx = torch.tensor(ctx_seed_norm[-cfg.model.seq_len:], dtype=TORCH_DTYPE)
    sim_rets_norm = generate_mrnd_returns(model, sched, ctx, cfg.data.n_paths_eval, cfg, device)
    sim_rets = normalizer.denormalize(sim_rets_norm)
    prices = returns_to_prices(s0, sim_rets, max_price=cfg.data.max_price)

    h30 = min(cfg.model.horizon_days, 30)
    sim_h1 = _sim_nonoverlap(sim_rets, 1)
    sim_h5 = _sim_nonoverlap(sim_rets, 5)
    sim_h30 = _sim_nonoverlap(sim_rets, h30)
    real_h1 = _real_nonoverlap(test_rets_raw, 1)
    real_h5 = _real_nonoverlap(test_rets_raw, 5)
    real_h30 = _real_nonoverlap(test_rets_raw, h30)

    ci_report = multi_horizon_ks_with_ci(sim_rets, test_rets_raw, horizons=(1, 5, h30))
    for h_val, ci in ci_report.items():
        LOGGER.info("KS_CI[h=%2d] ks=%.4f 95%%CI=[%.4f, %.4f] n_real=%-4d crit95=%.4f reject=%s",
                    h_val, ci["ks"], ci["ci_lo"], ci["ci_hi"], ci["n_real"], ci["critical_95"],
                    "YES (BAD)" if ci["reject_null"] else "no (good)")

    opt_rmse = float("nan")
    if not option_holdout.empty:
        pred = monte_carlo_call_prices_from_paths(prices, option_holdout["strike"].to_numpy(float),
                                                  option_holdout["tau"].to_numpy(float), cfg.data.risk_free)
        mkt = option_holdout["market_price"].to_numpy(float)
        opt_rmse = float(np.sqrt(np.mean((pred - mkt)**2)))
    mart = check_martingale_condition(prices, s0, cfg.data.risk_free, h30 / TRADING_DAYS)

    out: Dict[str, float] = {
        "P_KS1": compute_ks_distance(sim_h1, real_h1),
        "P_KS5": compute_ks_distance(sim_h5, real_h5),
        "P_KS30": compute_ks_distance(sim_h30, real_h30),
        "P_MMD1": compute_mmd(sim_h1, real_h1),
        "P_MMD5": compute_mmd(sim_h5, real_h5),
        "P_MMD30": compute_mmd(sim_h30, real_h30),
        "P_holdout_RMSE": opt_rmse,
        "martingale_ratio_P": mart["martingale_ratio"],
        "martingale_error_pct_P": mart["martingale_error_pct"],
        "P_n_real_h1": float(len(real_h1)),
        "P_n_real_h5": float(len(real_h5)),
        "P_n_real_h30": float(len(real_h30)),
    }
    for h_val in (1, 5, h30):
        prefix = f"P_KS{h_val}_"
        ci = ci_report.get(h_val, {})
        for k in ("ci_lo", "ci_hi", "critical_95"):
            if k in ci:
                out[prefix + k] = float(ci[k])
        if "reject_null" in ci:
            out[prefix + "reject_null"] = float(ci["reject_null"])
    return prices, out


def evaluate_q_measure(q_net, eval_paths: np.ndarray, s0: float, option_holdout: pd.DataFrame,
                       test_rets: np.ndarray, cfg: Config, device: str) -> Dict[str, float]:
    q_net.eval()
    step_feats = torch.tensor(build_girsanov_step_features(eval_paths, s0), dtype=TORCH_DTYPE, device=device)
    eval_prices_t = torch.tensor(eval_paths, dtype=TORCH_DTYPE, device=device)
    mu_ann = getattr(q_net, "_mu_ann", 0.0)
    sigma_ann = getattr(q_net, "_sigma_ann", 0.2)
    with torch.no_grad():
        lambdas = q_net(step_feats)
        log_w = compute_girsanov_log_weights(lambdas, eval_prices_t, s0, mu_ann, sigma_ann)
    q_w = girsanov_weights_from_log(log_w.cpu().numpy())

    terminal = np.log(np.clip(eval_paths[:, -1], SAFE_EPS, 1e9)) - np.log(max(s0, SAFE_EPS))
    rng = np.random.default_rng(cfg.seed + 999)
    draw_n = min(1500 * 2, len(terminal))
    q_sample = rng.choice(terminal, size=draw_n, replace=True, p=_normalise_weights(q_w))
    real_h30 = make_horizon_returns(test_rets, min(cfg.model.horizon_days, 30))
    real_h5 = make_horizon_returns(test_rets, 5)
    real_h1 = make_horizon_returns(test_rets, 1)

    hold_rmse = float("nan")
    if not option_holdout.empty:
        strikes = option_holdout["strike"].to_numpy(float)
        taus = option_holdout["tau"].to_numpy(float)
        market = option_holdout["market_price"].to_numpy(float)
        sq_errs = []
        for k, tau, mkt in zip(strikes, taus, market):
            step = min(eval_paths.shape[1]-1, max(1, int(round(TRADING_DAYS * tau))))
            st = eval_paths[:, step]
            payoff = np.maximum(st - float(k), 0.0)
            cq = float(np.exp(-cfg.data.risk_free * tau) * np.dot(q_w, payoff))
            sq_errs.append((cq - mkt)**2)
        hold_rmse = float(np.sqrt(np.mean(sq_errs))) if sq_errs else float("nan")

    mart = weighted_martingale_metrics(eval_paths, q_w, s0, cfg.data.risk_free, (eval_paths.shape[1]-1)/TRADING_DAYS)
    return {
        "Q_ESS": float(compute_ess(q_w)),
        "Q_KS30": compute_ks_distance(q_sample, real_h30),
        "Q_KS5": compute_ks_distance(q_sample, real_h5),
        "Q_KS1": compute_ks_distance(q_sample, real_h1),
        "Q_MMD30": compute_mmd(q_sample, real_h30),
        "Q_MMD5": compute_mmd(q_sample, real_h5),
        "Q_MMD1": compute_mmd(q_sample, real_h1),
        "Q_holdout_RMSE": hold_rmse,
        "martingale_ratio_Q": mart["martingale_ratio"],
        "martingale_error_pct_Q": mart["martingale_error_pct"],
    }


