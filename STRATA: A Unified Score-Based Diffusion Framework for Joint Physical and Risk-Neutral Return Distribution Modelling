def build_path_bank(model: ScoreNet, sched: VPSchedule, rets_norm: np.ndarray, n_anchors: int,
                    cfg: Config, device: str) -> np.ndarray:
    if len(rets_norm) < cfg.model.seq_len + cfg.model.horizon_days + 1:
        ctx_np = np.pad(rets_norm[-cfg.model.seq_len:], (max(0, cfg.model.seq_len - len(rets_norm[-cfg.model.seq_len:])), 0))[-cfg.model.seq_len:]
        ctx = torch.tensor(ctx_np, dtype=TORCH_DTYPE)
        r = generate_mrnd_returns(model, sched, ctx, cfg.data.n_paths_q_bank, cfg, device)
        return r
    max_start = len(rets_norm) - cfg.model.seq_len - cfg.model.horizon_days - 1
    starts = np.round(np.linspace(0, max_start, max(n_anchors, 1))).astype(int)
    all_paths = []
    for s in starts:
        ctx = torch.tensor(rets_norm[s:s+cfg.model.seq_len], dtype=TORCH_DTYPE)
        sim_rets = generate_mrnd_returns(model, sched, ctx, cfg.data.n_paths_q_bank, cfg, device)
        all_paths.append(sim_rets)
    return np.concatenate(all_paths, axis=0)


# -----------------------------------------------------------------------------
# Finance objective tree (for reporting)
# -----------------------------------------------------------------------------
def build_finance_objective_tree(metrics: Dict[str, float], cfg: Config) -> Dict[str, object]:
    _p_ks30 = metrics.get("P_KS30", 1.0)
    _p_mart = metrics.get("martingale_error_pct_P", 100.0)
    tree: Dict[str, object] = {
        "P_admissible": {
            "pass": bool(_p_ks30 < 0.55 and _p_mart < 5.0),
            "soft": bool(not (_p_ks30 < 0.38 and _p_mart < 5.0)),
        },
        "P_invalid_hard": {"pass": bool(metrics.get("P_KS30", 1.0) < cfg.data.p_invalid_ks_hard_cap)},
        "Q_stable": {"pass": bool(metrics.get("Q_ESS", 0.0) >= cfg.data.q_min_ess_frac_hard and
                                  metrics.get("martingale_error_pct_Q", 100.0) < 5.0)},
        "Q_beats_P_on_options": {"pass": bool(metrics.get("Q_holdout_RMSE", 1e9) <= metrics.get("P_holdout_RMSE", 1e9)), "soft": True},
        "Q_beats_GBM_on_KS30": {"pass": bool(metrics.get("Q_KS30", 1e9) <= metrics.get(f"GBM_KS{min(cfg.model.horizon_days,30)}", 1e9)), "soft": True},
    }
    tree["continue_to_results"] = bool(tree["P_admissible"]["pass"] and tree["P_invalid_hard"]["pass"] and tree["Q_stable"]["pass"])
    return tree


