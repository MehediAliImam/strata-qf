    out["martingale_ratio_GBM"] = check_martingale_condition(gbm, s0, cfg.data.risk_free, cfg.data.baseline_steps/TRADING_DAYS)["martingale_ratio"]

    hp = fit_heston_params(train_rets, option_surface=option_holdout, s0=s0, rate=cfg.data.risk_free)
