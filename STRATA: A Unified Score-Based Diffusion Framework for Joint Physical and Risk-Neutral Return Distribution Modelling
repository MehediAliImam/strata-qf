# Return Normalisation
# -----------------------------------------------------------------------------
@dataclass
class ReturnNormalizer:
    mean: float
    std: float

    def normalize(self, x: np.ndarray) -> np.ndarray:
        return (x - self.mean) / max(self.std, SAFE_EPS)

    def denormalize(self, x: np.ndarray) -> np.ndarray:
        return x * max(self.std, SAFE_EPS) + self.mean


def fit_return_normalizer(train_rets: np.ndarray, floor: float = 1e-4) -> ReturnNormalizer:
    mu = float(np.mean(train_rets))
    sigma = float(np.std(train_rets, ddof=0))
    return ReturnNormalizer(mean=mu, std=max(sigma, floor))


